{
  "Exercise": "Shadow Mapping with Directional Light",

  "Window": {
    "Width": 1024,
    "Height": 1024,
    "Name": "LearnOpenGL => Shadow Mapping with Directional Light"
  },

  "CameraSettings": {
    "FOV": 45.0,
    "MovementSpeed": 1.0,
    "LookSpeed": 0.1,
    "NearPlane": 0.1,
    "FarPlane": 100.0
  },

  "ModelAssets": {
    "Model3D": "stanford-bunny/model.dae",
    "BunnyTexture": "stanford-bunny/textures/DefaultMaterial_diffuse.jpg",
    "WindowTexture": "blending_transparent_window.png",
    "FloorTexture": "wooden-floor-texture.jpg"
  },

  "ModelShader": {
    "Vertex": "Shadow Mapping Shaders/Model-Vertex.shader",
    "Frag": "Shadow Mapping Shaders/Model-Blinn-Phong-Frag.shader"
  },

  "ScreenShader": {
    "Vertex": "Shadow Mapping Shaders/FrameBuffer-Screen-Vertex.shader",
    "Frag": "Shadow Mapping Shaders/FrameBuffer-Screen-Frag.shader"
  },

  "DepthModelShader": {
    "Vertex": "Shadow Mapping Shaders/DepthFB-Vertex.shader",
    "Frag": "Shadow Mapping Shaders/DepthFB-Frag.shader"
  },

  "DebugScreenShader": {
    "Vertex": "Shadow Mapping Shaders/FrameBuffer-Screen-Vertex.shader",
    "Frag": "Shadow Mapping Shaders/Debug-FrameBuffer-Screen-Frag.shader"
  },

  "SkyboxTextures": [
    "skybox/right.jpg",
    "skybox/left.jpg",
    "skybox/top.jpg",
    "skybox/bottom.jpg",
    "skybox/front.jpg",
    "skybox/back.jpg"
  ],
  "SkyboxShader": {
    "Vertex": "Skyboxes/skybox_vertex.shader",
    "Frag": "Skyboxes/skybox_frag.shader"
  },

  "Internal Comments": {
    "Other screenShader effects": [
      "Framebuffer basics/screen_frag_blurr.shader",
      "Framebuffer basics/screen_frag_invert.shader",
      "Framebuffer basics/screen_frag_grayscale.shader",
      "Framebuffer basics/screen_frag_sharpen.shader",
      "Framebuffer basics/screen_frag_edge-detect.shader",
      "Framebuffer basics/screen_frag_basic.shader"
    ]
  }
}